#!/usr/bin/env python3
"""zenvx-download-model - downloads the selected GGUF model with a progress bar."""
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.request

SELECTED = "/var/lib/zenvx/selected_model"
CONFIG_JSON = "/etc/zenvx/config.json"
MODELS_DIR = "/opt/zenvx/models"
DONE_FLAG = "/var/lib/zenvx/.model_downloaded"

MODELS = {
    "llama3-1b-q4": (
        "https://huggingface.co/bartowski/Llama-3.2-1B-Instruct-GGUF/"
        "resolve/main/Llama-3.2-1B-Instruct-Q4_K_M.gguf", "llama3-1b-q4.gguf"),
    "llama3-3b-q4": (
        "https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF/"
        "resolve/main/Llama-3.2-3B-Instruct-Q4_K_M.gguf", "llama3-3b-q4.gguf"),
    "llama3-8b-q4": (
        "https://huggingface.co/bartowski/Meta-Llama-3-8B-Instruct-GGUF/"
        "resolve/main/Meta-Llama-3-8B-Instruct-Q4_K_M.gguf", "llama3-8b-q4.gguf"),
}

CHUNK = 64 * 1024


def human(n):
    for unit in ("B", "KB", "MB", "GB"):
        if n < 1024:
            return f"{n:.1f}{unit}"
        n /= 1024
    return f"{n:.1f}TB"


def has_network():
    try:
        subprocess.run(["ping", "-c", "1", "-W", "3", "huggingface.co"],
                       capture_output=True, timeout=8, check=True)
        return True
    except (subprocess.SubprocessError, OSError):
        return False


def progress(downloaded, total, start):
    width = 40
    frac = downloaded / total if total else 0
    filled = int(width * frac)
    bar = "\u2588" * filled + "\u2591" * (width - filled)
    elapsed = max(time.time() - start, 1e-6)
    speed = downloaded / elapsed
    eta = (total - downloaded) / speed if speed > 0 and total else 0
    sys.stdout.write(
        f"\r  [{bar}] {frac * 100:5.1f}%  "
        f"{human(downloaded)}/{human(total)}  "
        f"{human(speed)}/s  ETA {int(eta)}s   ")
    sys.stdout.flush()


def download_urllib(url, dest):
    tmp = dest + ".tmp"
    req = urllib.request.Request(url, headers={"User-Agent": "zenvx/0.1"})
    with urllib.request.urlopen(req, timeout=30) as resp:
        total = int(resp.headers.get("Content-Length", 0))
        start = time.time()
        downloaded = 0
        with open(tmp, "wb") as out:
            while True:
                chunk = resp.read(CHUNK)
                if not chunk:
                    break
                out.write(chunk)
                downloaded += len(chunk)
                progress(downloaded, total, start)
    os.rename(tmp, dest)
    print()


def download_wget(url, dest):
    print("  urllib failed; falling back to wget...")
    subprocess.run(["wget", "-O", dest, url], check=True)


def main():
    try:
        with open(SELECTED) as f:
            key = f.read().strip()
    except OSError:
        print("No model selected.")
        return 1
    if key not in MODELS:
        print(f"Unknown model key: {key}")
        return 1

    url, filename = MODELS[key]
    os.makedirs(MODELS_DIR, exist_ok=True)
    dest = os.path.join(MODELS_DIR, filename)

    if os.path.exists(dest):
        print(f"  Model already present: {dest}")
    else:
        if not has_network():
            print("  No network. Launching nmtui to configure connectivity...")
            if shutil.which("nmtui"):
                subprocess.run(["nmtui"])
            if not has_network():
                print("  Still offline. Re-run zenvx-download-model later.")
                return 1
        print(f"  Downloading {filename} ...")
        try:
            download_urllib(url, dest)
        except Exception as exc:  # noqa: BLE001
            print(f"\n  urllib error: {exc}")
            try:
                download_wget(url, dest)
            except (subprocess.SubprocessError, OSError) as exc2:
                print(f"  wget error: {exc2}")
                return 1

    open(DONE_FLAG, "w").close()
    try:
        with open(CONFIG_JSON) as f:
            config = json.load(f)
    except (OSError, ValueError):
        config = {}
    config.setdefault("models", {})
    config["models"]["llm"] = dest
    with open(CONFIG_JSON, "w") as f:
        json.dump(config, f, indent=2)
    print("  Model ready.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

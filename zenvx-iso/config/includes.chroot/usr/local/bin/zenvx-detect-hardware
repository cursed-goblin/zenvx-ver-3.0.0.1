#!/usr/bin/env python3
"""zenvx-detect-hardware - probes the machine and writes a hardware profile."""
import json
import os
import re
import shutil
import subprocess

HARDWARE_JSON = "/var/lib/zenvx/hardware.json"
CONFIG_JSON = "/etc/zenvx/config.json"
RECOMMENDED = "/var/lib/zenvx/recommended_model"


def total_ram_mb():
    try:
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    return int(int(line.split()[1]) / 1024)
    except OSError:
        pass
    return 2048


def cpu_model():
    try:
        with open("/proc/cpuinfo") as f:
            for line in f:
                if "model name" in line:
                    return line.split(":", 1)[1].strip()
    except OSError:
        pass
    return "Unknown CPU"


def detect_gpu():
    name, vram, cuda = None, 0, False
    if shutil.which("nvidia-smi"):
        try:
            out = subprocess.run(
                ["nvidia-smi", "--query-gpu=name,memory.total",
                 "--format=csv,noheader,nounits"],
                capture_output=True, text=True, timeout=10,
            )
            if out.returncode == 0 and out.stdout.strip():
                first = out.stdout.strip().splitlines()[0]
                parts = [p.strip() for p in first.split(",")]
                name = parts[0]
                vram = int(float(parts[1]))
                cuda = True
                return name, vram, cuda
        except (subprocess.SubprocessError, ValueError, OSError):
            pass
    # Fallback: parse lspci
    if shutil.which("lspci"):
        try:
            out = subprocess.run(["lspci"], capture_output=True, text=True, timeout=10)
            for line in out.stdout.splitlines():
                if re.search(r"VGA|3D|Display", line) and "NVIDIA" in line.upper():
                    name = line.split(":")[-1].strip()
                    break
        except (subprocess.SubprocessError, OSError):
            pass
    return name, vram, cuda


def has_vulkan():
    if not shutil.which("vulkaninfo"):
        return False
    try:
        out = subprocess.run(["vulkaninfo"], capture_output=True, text=True, timeout=10)
        return out.returncode == 0
    except (subprocess.SubprocessError, OSError):
        return False


def disk_free_mb(path="/"):
    try:
        st = os.statvfs(path)
        return int(st.f_bavail * st.f_frsize / (1024 * 1024))
    except OSError:
        return 0


def compute_tier(ram_mb):
    if ram_mb >= 7 * 1024:
        return "high"
    if ram_mb >= 4 * 1024:
        return "mid"
    return "low"


def compute_gpu_layers(cuda, vram_mb):
    if not cuda:
        return 0
    if vram_mb >= 4096:
        return 35
    if vram_mb >= 2048:
        return 20
    if vram_mb >= 512:
        return 10
    return 0


def compute_threads(tier, cores):
    if tier == "high":
        return min(cores or 8, 8)
    if tier == "mid":
        return 4
    return 2


def compute_context(tier):
    return {"high": 2048, "mid": 1024, "low": 512}[tier]


def compute_ram_budget(tier):
    return {"high": 4096, "mid": 2048, "low": 768}[tier]


def recommend_model(ram_mb):
    if ram_mb >= 6 * 1024:
        return "llama3-8b-q4"
    if ram_mb >= int(3.5 * 1024):
        return "llama3-3b-q4"
    return "llama3-1b-q4"


def main():
    ram = total_ram_mb()
    cores = os.cpu_count() or 1
    cpu = cpu_model()
    gpu_name, vram, cuda = detect_gpu()
    vulkan = has_vulkan()
    disk = disk_free_mb()
    tier = compute_tier(ram)
    gpu_layers = compute_gpu_layers(cuda, vram)
    threads = compute_threads(tier, cores)
    context = compute_context(tier)
    ram_budget = compute_ram_budget(tier)
    model = recommend_model(ram)

    profile = {
        "ram_mb": ram,
        "cpu_cores": cores,
        "cpu_model": cpu,
        "gpu_name": gpu_name,
        "vram_mb": vram,
        "cuda": cuda,
        "vulkan": vulkan,
        "disk_free_mb": disk,
        "tier": tier,
        "gpu_layers": gpu_layers,
        "inference_threads": threads,
        "context_size": context,
        "max_ram_mb": ram_budget,
        "recommended_model": model,
    }

    os.makedirs(os.path.dirname(HARDWARE_JSON), exist_ok=True)
    with open(HARDWARE_JSON, "w") as f:
        json.dump(profile, f, indent=2)

    try:
        with open(CONFIG_JSON) as f:
            config = json.load(f)
    except (OSError, ValueError):
        config = {}
    config.setdefault("hardware", {})
    config["hardware"].update({
        "max_ram_mb": ram_budget,
        "inference_threads": threads,
        "gpu_layers": gpu_layers,
        "context_size": context,
        "quantization": "q4",
    })
    with open(CONFIG_JSON, "w") as f:
        json.dump(config, f, indent=2)

    with open(RECOMMENDED, "w") as f:
        f.write(model)

    print(json.dumps(profile, indent=2))
    return profile


if __name__ == "__main__":
    main()

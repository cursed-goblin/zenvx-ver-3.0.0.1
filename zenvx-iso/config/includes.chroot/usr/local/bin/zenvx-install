#!/usr/bin/env python3
"""zenvx-install - installs the live ZenvX system permanently to a disk."""
import os
import re
import subprocess
import sys

CYAN = "\033[38;2;0;255;204m"
BOLD = "\033[1m"
RED = "\033[31m"
RESET = "\033[0m"
TARGET = "/mnt/zenvx-install"
EXCLUDES = ["/proc", "/sys", "/dev", "/run", "/tmp", "/mnt", "/media",
            "/live", "/cdrom"]


def sh(cmd, **kw):
    print(f"  $ {' '.join(cmd)}")
    return subprocess.run(cmd, check=True, **kw)


def sh_out(cmd):
    return subprocess.run(cmd, capture_output=True, text=True, check=True).stdout


def detect_boot_mode():
    mode = "UEFI" if os.path.exists("/sys/firmware/efi") else "BIOS"
    print(f"{CYAN}Detected boot mode: {mode}{RESET}")
    return mode


def part_suffix(disk, n):
    base = os.path.basename(disk)
    if base.startswith("nvme") or base.startswith("mmcblk"):
        return f"{disk}p{n}"
    return f"{disk}{n}"


def select_disk():
    print("\nAvailable disks:")
    out = sh_out(["lsblk", "-dno", "NAME,SIZE,MODEL,TYPE"])
    disks = []
    for line in out.splitlines():
        parts = line.split(None, 3)
        if len(parts) >= 2 and parts[-1].strip() == "disk":
            disks.append(parts[0])
        elif "disk" in line:
            disks.append(line.split()[0])
    disks = [d for d in disks if d]
    for i, d in enumerate(disks, 1):
        info = sh_out(["lsblk", "-dno", "SIZE,MODEL", f"/dev/{d}"]).strip()
        print(f"  [{i}] /dev/{d}  {info}")
    while True:
        choice = input("Select target disk number: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= len(disks):
            return f"/dev/{disks[int(choice) - 1]}"
        print("Invalid selection.")


def confirm_and_partition(disk, mode):
    print(f"\n{RED}{BOLD}WARNING: ALL DATA ON {disk} WILL BE ERASED.{RESET}")
    if input("Type 'yes' to continue: ").strip().lower() != "yes":
        print("Aborted.")
        sys.exit(1)
    sh(["wipefs", "-a", disk])
    sh(["sgdisk", "--zap-all", disk])
    if mode == "UEFI":
        sh(["sgdisk", "-n", "1:0:+512M", "-t", "1:EF00", "-c", "1:EFI", disk])
        sh(["sgdisk", "-n", "2:0:0", "-t", "2:8300", "-c", "2:ZENVX-ROOT", disk])
        return part_suffix(disk, 1), part_suffix(disk, 2)
    sh(["sgdisk", "-n", "1:0:+1M", "-t", "1:EF02", "-c", "1:BIOSBOOT", disk])
    sh(["sgdisk", "-n", "2:0:0", "-t", "2:8300", "-c", "2:ZENVX-ROOT", disk])
    return None, part_suffix(disk, 2)


def format_partitions(efi, root, mode):
    if mode == "UEFI" and efi:
        sh(["mkfs.vfat", "-F", "32", "-n", "EFI", efi])
    sh(["mkfs.ext4", "-F", "-L", "ZENVX-ROOT", root])


def mount_partitions(efi, root, mode):
    os.makedirs(TARGET, exist_ok=True)
    sh(["mount", root, TARGET])
    if mode == "UEFI" and efi:
        os.makedirs(f"{TARGET}/boot/efi", exist_ok=True)
        sh(["mount", efi, f"{TARGET}/boot/efi"])


def copy_system():
    cmd = ["rsync", "-aHAX", "--info=progress2"]
    for ex in EXCLUDES:
        cmd += ["--exclude", ex + "/*"]
    cmd += ["/", TARGET + "/"]
    sh(cmd)
    for d in ("proc", "sys", "dev", "run", "tmp", "mnt", "media"):
        os.makedirs(f"{TARGET}/{d}", exist_ok=True)


def uuid_of(dev):
    return sh_out(["blkid", "-s", "UUID", "-o", "value", dev]).strip()


def write_fstab(efi, root, mode):
    lines = ["# /etc/fstab generated by zenvx-install",
             f"UUID={uuid_of(root)} / ext4 defaults,relatime 0 1"]
    if mode == "UEFI" and efi:
        lines.append(f"UUID={uuid_of(efi)} /boot/efi vfat umask=0077 0 2")
    with open(f"{TARGET}/etc/fstab", "w") as f:
        f.write("\n".join(lines) + "\n")


def install_bootloader(disk, mode):
    for d in ("proc", "sys", "dev"):
        sh(["mount", "--bind", f"/{d}", f"{TARGET}/{d}"])
    sh(["mount", "--bind", "/dev/pts", f"{TARGET}/dev/pts"])
    sh(["mount", "--bind", "/run", f"{TARGET}/run"])
    if mode == "UEFI":
        sh(["chroot", TARGET, "grub-install", "--target=x86_64-efi",
            "--efi-directory=/boot/efi", "--bootloader-id=ZenvX",
            "--recheck"])
    else:
        sh(["chroot", TARGET, "grub-install", "--target=i386-pc",
            "--recheck", disk])
    sh(["chroot", TARGET, "update-grub"])
    for mp in ("dev/pts", "proc", "sys", "dev", "run"):
        subprocess.run(["umount", f"{TARGET}/{mp}"], check=False)


def cleanup_reboot(disk):
    subprocess.run(["umount", "-R", TARGET], check=False)
    print(f"\n{CYAN}{BOLD}ZenvX OS installed to {disk}.{RESET}")
    if input("Reboot now? [yes/no]: ").strip().lower() in ("y", "yes"):
        sh(["reboot"])


def main():
    if os.geteuid() != 0:
        print("Run with sudo.")
        return 1
    print(f"{CYAN}{BOLD}ZenvX OS Disk Installer{RESET}")
    mode = detect_boot_mode()
    disk = select_disk()
    efi, root = confirm_and_partition(disk, mode)
    format_partitions(efi, root, mode)
    mount_partitions(efi, root, mode)
    copy_system()
    write_fstab(efi, root, mode)
    install_bootloader(disk, mode)
    cleanup_reboot(disk)
    return 0


if __name__ == "__main__":
    sys.exit(main())
